{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorkBuddy 模型配置",
  "version": "0.2.4",
  "identifier": "com.workbuddytools.modelconfig",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WorkBuddy 模型配置",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCNzJCNzgyQjcxQkJEOEIKUldTTHZSdTNncmR5aTkwRVVhRjRSeEJFOWM3TEJFT2R6TkQvditwNnBTL3BQekpjQnFzVDM5YUsK",
      "endpoints": [
        "https://github.com/gcdd1993/WorkBuddyTools/releases/latest/download/latest.json"
      ]
    }
  }
}
